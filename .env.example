# Copy to ".env" and adjust as needed. Never commit the real .env file.

# --- PostgreSQL (container) -------------------------------------------------
POSTGRES_USER=fluuser
POSTGRES_PASSWORD=flupass
POSTGRES_DB=flu_database

# --- Application database connection (used by the package and the API) ------
APP_DB_USER=fluuser
APP_DB_PASSWORD=flupass
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=flu_database

# --- Airflow ----------------------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_SECRET_KEY=please-change-me
# Set to your host user id on Linux to avoid file-permission issues:
#   echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# --- API --------------------------------------------------------------------
# Host port the dashboard is published on (container always listens on 5000).
API_PORT=5001
